diff --git a/tests/test_category_filter.py b/tests/test_category_filter.py
new file mode 100644
index 0000000..af87d39
--- /dev/null
+++ b/tests/test_category_filter.py
@@ -0,0 +1,32 @@
+import os
+import sys
+
+from starlette.testclient import TestClient
+
+sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
+
+from api.main import app
+
+
+client = TestClient(app)
+
+
+def test_no_category_returns_quote():
+    response = client.get("/api/quote")
+
+    assert response.status_code == 200
+    assert response.json()["quote"]
+
+
+def test_life_category_returns_non_empty_quote():
+    response = client.get("/api/quote", params={"category": "life"})
+
+    assert response.status_code == 200
+    assert response.json()["quote"]
+
+
+def test_nonexistent_category_returns_404():
+    response = client.get("/api/quote", params={"category": "nonexistent_xyz"})
+
+    assert response.status_code == 404
+    assert response.json()["detail"] == "No quotes found for that category."
